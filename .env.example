# Second Me OAuth
SECONDME_CLIENT_ID=your_client_id
SECONDME_CLIENT_SECRET=your_client_secret

# Zhihu API (AK/SK signing)
ZHIHU_AK=your_zhihu_ak
ZHIHU_SK=your_zhihu_sk
ZHIHU_CIRCLE_ID=

# AI Builder Space (auto-injected in production as AI_BUILDER_TOKEN)
AI_BUILDER_TOKEN=your_ai_builder_token

# Turso (optional — falls back to file-based storage if not set)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# App
BASE_URL=http://localhost:8000
SESSION_SECRET=change-me-to-random-string
